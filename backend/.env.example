# Required
JWT_SECRET=replace_with_long_random_secret

# PostgreSQL — установите сервер локально, создайте БД и пользователя, затем укажите строку подключения:
#   createdb blockchain_auth   или через pgAdmin / psql CREATE DATABASE ...
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/blockchain_auth

# Server
PORT=4000
APP_DOMAIN=localhost
NODE_ENV=development

# Token lifetimes
JWT_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d
NONCE_TTL_SECONDS=300

# Optional hardening
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=80
# Comma separated exact origins, e.g. https://myapp.com,https://staging.myapp.com
CORS_ORIGINS=

# Admin API + /admin UI — checksummed 0x addresses (comma-separated)
ADMIN_ADDRESSES=0xC5A5CB6b6A11b5AE6292ca3fa95a0b495046EB15

# AI-ассистент (Gemini) — ключ: https://aistudio.google.com/apikey
# Только на сервере; не коммитьте реальный ключ.
GEMINI_API_KEY=
# Модель: gemini-2.5-flash (стабильная). При 429 попробуйте gemini-2.5-flash-lite или gemini-flash-latest
GEMINI_MODEL=gemini-2.5-flash

# --- Render.com ---
# PORT задаётся платформой. DATABASE_URL — Internal URL из PostgreSQL на Render.
# APP_DOMAIN — хост без схемы, напр. your-service.onrender.com (для SIWE).
# CORS_ORIGINS — полный URL фронта, напр. https://your-app.vercel.app
